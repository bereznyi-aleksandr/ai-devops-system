{
  "version": 3,
  "purpose": "Map logical providers to concrete execution adapters. Role FSM chooses role; routing chooses provider; provider adapter chooses workflow. GPT hosted is the default analyst/report contour; GPT Codex is the write-capable reserve coding contour and can also serve analyst in fallback mode.",
  "default_provider": "gpt",
  "adapters": {
    "gpt": {
      "enabled": true,
      "mode": "workflow_dispatch",
      "workflow": "gpt-hosted-roles.yml",
      "runner": "github-hosted",
      "supports_roles": [
        "analyst",
        "auditor",
        "executor",
        "curator"
      ],
      "capabilities": {
        "read_repo": true,
        "write_repo": false,
        "commit": false
      },
      "notes": "Hosted GPT role runner is the primary analyst/report contour. If it becomes unhealthy, analyst can fail over through the role fallback chain."
    },
    "gpt_hosted_fallback": {
      "enabled": true,
      "mode": "workflow_dispatch",
      "workflow": "gpt-hosted-roles.yml",
      "runner": "github-hosted",
      "supports_roles": [
        "analyst",
        "auditor",
        "executor",
        "curator"
      ],
      "capabilities": {
        "read_repo": true,
        "write_repo": false,
        "commit": false
      },
      "notes": "Hosted GPT fallback for curator/analysis/reporting. Not the write-capable GPT Codex contour."
    },
    "gpt_codex": {
      "enabled": true,
      "mode": "workflow_dispatch",
      "workflow": "codex-local.yml",
      "runner": "self-hosted:codex-local",
      "supports_roles": [
        "analyst",
        "auditor",
        "executor"
      ],
      "capabilities": {
        "read_repo": true,
        "write_repo": true,
        "commit": true
      },
      "requires": [
        "self-hosted runner",
        "local Codex CLI",
        "AI_SYSTEM_GITHUB_PAT"
      ],
      "notes": "Write-capable GPT Codex reserve contour. For analyst it works as read/plan fallback; for auditor/executor it can participate in the coding contour."
    },
    "codex": {
      "enabled": true,
      "mode": "workflow_dispatch",
      "workflow": "codex-local.yml",
      "runner": "self-hosted:codex-local",
      "supports_roles": [
        "analyst",
        "auditor",
        "executor",
        "curator"
      ],
      "capabilities": {
        "read_repo": true,
        "write_repo": true,
        "commit": true
      },
      "requires": [
        "self-hosted runner",
        "local Codex CLI",
        "AI_SYSTEM_GITHUB_PAT"
      ]
    },
    "isa_patch_runner": {
      "enabled": true,
      "mode": "workflow_dispatch",
      "workflow": "isa-patch-runner.yml",
      "runner": "github-hosted",
      "supports_roles": [
        "executor"
      ],
      "capabilities": {
        "read_repo": true,
        "write_repo": true,
        "commit": true
      },
      "notes": "Patch runner is not a conversational role adapter. Use only for approved patch tasks."
    },
    "claude": {
      "enabled": false,
      "mode": "legacy_issue_comment",
      "workflow": "claude.yml",
      "runner": "github-hosted",
      "supports_roles": [
        "analyst",
        "auditor",
        "executor",
        "curator"
      ],
      "capabilities": {
        "read_repo": true,
        "write_repo": true,
        "commit": true
      },
      "disabled_reason": "Claude is disabled for internal FSM while limits are active. Use role reserve provider."
    }
  },
  "fallback_rules": {
    "adapter_missing": "use_role_reserve_or_default_provider",
    "adapter_disabled": "use_role_reserve_or_default_provider",
    "adapter_does_not_support_role": "use_role_reserve_or_default_provider",
    "provider_limited": "use_role_reserve_or_default_provider",
    "provider_unhealthy": "skip_provider_and_continue_fallback_chain"
  }
}

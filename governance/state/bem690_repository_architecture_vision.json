{
  "schema_version": "repository_architecture_vision.v1",
  "bem": "BEM-690",
  "status": "draft_ready",
  "principles": [
    "Repository is a control-plane, not just a code folder.",
    "One source of truth for runtime state: governance/runtime.",
    "Product workspaces are separated from system governance.",
    "Board of Directors domains are configured in registry, not hardcoded in workflows.",
    "Every task has trace_id, owner, lane, status, evidence, result, audit trail.",
    "Risk-based controls: fast lane for low risk, audit lane for architecture or sensitive work, operator lane for strategic/high-risk decisions.",
    "Workflows stay thin; long logic lives in scripts.",
    "Repo structure must support later split into multiple repositories without rewriting governance model."
  ],
  "recommended_structure": "\n/\n├── README.md\n├── docs/                              # human documentation, product docs, operator docs\n│   ├── architecture/\n│   ├── operator/\n│   └── runbooks/\n├── governance/                        # control plane of the autonomous system\n│   ├── protocols/                     # каноны и правила\n│   ├── roadmap/                       # стратегические и BEM-дорожные карты\n│   ├── runtime/                       # registry v2: источник истины\n│   │   ├── tasks/                     # активные задачи\n│   │   ├── results/                   # результаты задач\n│   │   ├── agents/                    # состояние агентов/ролей\n│   │   ├── domains/                   # совет директоров / домены бизнеса\n│   │   ├── decisions/                 # решения директоров/оператора\n│   │   ├── controls/                  # control checks, gates, policies\n│   │   ├── checkpoints/               # resume-points для error recovery\n│   │   └── audit/                     # audit trail\n│   ├── audit_mailbox/                 # только связь аудиторов\n│   ├── internal_contour/              # текущий file-based внутренний контур, постепенно мигрирует в runtime/\n│   ├── codex/                         # write-channel tasks/results/proofs\n│   ├── reports/                       # operator/audit reports\n│   └── state/                         # legacy state до миграции в runtime/\n├── agents/                            # runtime contracts and adapters\n│   ├── board/                         # domain directors\n│   ├── roles/                         # analyst/auditor/executor/monitor\n│   └── adapters/                      # github, telegram, crm, accounting\n├── scripts/                           # all logic called by workflows\n├── .github/workflows/                 # thin workflow entrypoints only\n├── products/                          # бизнес-продукты внутри mono-repo на первом этапе\n│   ├── shared/\n│   └── barber-staff/\n│       ├── docs/\n│       ├── src/\n│       ├── tests/\n│       └── governance-link.json\n└── integrations/                      # external integrations schemas/connectors\n    ├── telegram/\n    ├── github/\n    ├── accounting/\n    └── crm/\n",
  "repo_strategy": [
    {
      "option": "Mono-repo now",
      "description": "Система управления и первые продукты в одном репозитории, но с жёстким разделением governance/, agents/, products/.",
      "when": "текущий этап и первый продукт",
      "pros": "проще контроль, единый audit trail, меньше инфраструктуры",
      "cons": "при росте может стать тяжёлым"
    },
    {
      "option": "Hybrid next",
      "description": "governance/control-plane остаётся в ai-devops-system; продукты могут быть отдельными репозиториями, подключёнными через product registry.",
      "when": "когда появится 2+ продукта или отдельные клиенты",
      "pros": "масштабируется, продукты изолированы, управление единое",
      "cons": "нужны cross-repo adapters и permissions"
    },
    {
      "option": "Multi-repo later",
      "description": "каждый продукт и каждый крупный домен в отдельном repo; control-plane управляет ими через registry и API.",
      "when": "несколько клиентов/SLA/product teams",
      "pros": "максимальная изоляция и масштаб",
      "cons": "сложнее orchestration, больше DevOps"
    }
  ],
  "registries": [
    {
      "path": "governance/runtime/domains/directors.json",
      "purpose": "Совет директоров: домены, полномочия, SLA, escalation."
    },
    {
      "path": "governance/runtime/agents/agents.json",
      "purpose": "Агенты/роли: lifecycle, runner, permissions, health."
    },
    {
      "path": "governance/runtime/tasks/*.json",
      "purpose": "Активные задачи: trace_id, owner, lane, status, dependencies."
    },
    {
      "path": "governance/runtime/results/*.json",
      "purpose": "Результаты: immutable evidence, commit, controls, status."
    },
    {
      "path": "governance/runtime/controls/policies.json",
      "purpose": "Risk-based lanes, blocking criteria, approval thresholds."
    },
    {
      "path": "governance/runtime/checkpoints/*.json",
      "purpose": "Checkpoint/resume для error recovery."
    },
    {
      "path": "governance/runtime/audit/*.jsonl",
      "purpose": "Append-only audit trail."
    },
    {
      "path": "products/product_registry.json",
      "purpose": "Список продуктов, владельцы-директора, repo/path, SLA, status."
    }
  ],
  "migration_steps": [
    {
      "step": "M1",
      "name": "Repo skeleton",
      "result": "Создать docs/, agents/, products/, governance/runtime/ skeleton with README per folder."
    },
    {
      "step": "M2",
      "name": "Runtime registry v2",
      "result": "Ввести схемы tasks/results/agents/domains/controls/checkpoints/audit."
    },
    {
      "step": "M3",
      "name": "Board registry",
      "result": "Описать директоров доменов, полномочия, escalation, KPI/SLA."
    },
    {
      "step": "M4",
      "name": "Product registry",
      "result": "Описать продукты и связь продукта с доменами/директорами."
    },
    {
      "step": "M5",
      "name": "Role-runtime contracts",
      "result": "Контракты analyst/auditor/executor/monitor/board-director."
    },
    {
      "step": "M6",
      "name": "Role-specific runners",
      "result": "Отдельные runners, но одинаковая схема registry/evidence."
    },
    {
      "step": "M7",
      "name": "Hybrid split readiness",
      "result": "Подготовить products/* так, чтобы продукт можно было вынести в отдельный repo без потери управления."
    }
  ],

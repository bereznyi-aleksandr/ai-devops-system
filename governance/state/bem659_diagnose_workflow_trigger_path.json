  "codex_runner_preview": [
    "name: Codex Runner",
    "",
    "# BEM-526: Python executor v3",
    "# BEM-645: fixed duplicate permissions key",
    "",
    "on:",
    "  workflow_dispatch:",
    "    inputs:",
    "      trace_id:",
    "        description: 'Trace ID'",
    "        required: true",
    "        type: string",
    "      task_path:",
    "        description: 'Override task file path'",
    "        required: false",
    "        default: ''",
    "        type: string",
    "",
    "permissions:",
    "  contents: write",
    "  actions: read",
    "",
    "jobs:",
    "  codex-runner:",
    "    name: Codex Runner v3 (ubuntu-latest)",
    "    runs-on: ubuntu-latest",
    "    timeout-minutes: 15",
    "",
    "    steps:",
    "      - name: Checkout",
    "        uses: actions/checkout@v4",
    "        with:",
    "          fetch-depth: 1",
    "          token: ${{ secrets.AI_SYSTEM_GITHUB_PAT || github.token }}",
    "",
    "      - name: Sync latest main",
    "        shell: bash",
    "        run: |",
    "          git config user.email \"codex-runner@ai-devops-system\"",
    "          git config user.name  \"Codex Runner\"",
    "          git fetch origin main",
    "          git checkout main",
    "          git reset --hard origin/main",
    "",
    "      - name: Read task file",
    "        shell: bash",
    "        env:",
    "          INPUT_TRACE_ID:  ${{ inputs.trace_id }}",
    "          INPUT_TASK_PATH: ${{ inputs.task_path }}",
    "        run: |",
    "          python3 - <<'PYEOF'",
    "          import json, os",
    "          from pathlib import Path",
    "",
    "          trace     = os.environ['INPUT_TRACE_ID']",
    "          task_path = os.environ.get('INPUT_TASK_PATH') or ('governance/codex/tasks/' + trace + '.json')",
    "          env_file  = os.environ['GITHUB_ENV']",
    "",
    "          p = Path(task_path)",
    "          if not p.exists():",
    "              print('Task file not found: ' + task_path)",
    "              with open(env_file, 'a') as f:",
    "                  f.write('TASK_FOUND=false\\n')",
    "                  f.write('TASK_OBJECTIVE=\\n')",
    "                  f.write('TASK_TYPE=unknown\\n')",
    "                  f.write('TRACE_ID=' + trace + '\\n')",
    "          else:",
    "              task      = json.loads(p.read_text())",
    "              objective = task.get('objective', '')",
    "              task_type = task.get('task_type', 'unknown')",
    "              title     = task.get('title', 'untitled')",
    "              print('Task: ' + title)",
    "              print('Type: ' + task_type)",
    "              with open(env_file, 'a') as f:",
    "                  f.write('TASK_FOUND=true\\n')",
    "                  f.write('TASK_TITLE=' + title.replace('\\n',' ') + '\\n')",
    "                  f.write('TASK_OBJECTIVE=' + objective[:3000].replace('\\n',' ') + '\\n')",
    "                  f.write('TASK_TYPE=' + task_type + '\\n')",
    "                  f.write('TRACE_ID=' + trace + '\\n')",
    "          PYEOF",
    "",
    "      - name: Execute task",
    "        if: env.TASK_FOUND == 'true'",
    "        shell: bash",
    "        run: |",
    "          python3 - <<'PYEOF'",
    "          import json, os, re, shutil",
    "          from datetime import datetime, timezone",
    "          from pathlib import Path",
    "",
    "          now       = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')",
    "          trace     = os.environ.get('TRACE_ID', 'unknown')",
    "          objective = os.environ.get('TASK_OBJECTIVE', '')",
    "          task_type = os.environ.get('TASK_TYPE', 'unknown')",
    "",
    "          task_path = 'governance/codex/tasks/' + trace + '.json'",
    "          try:",
    "              full_task = json.loads(Path(task_path).read_text())",
    "              objective = full_task.get('objective', objective)",
    "          except Exception:",
    "              pass",
    "",
    "          print('Executing: ' + trace)",
    "",
    "          changed_files = []",
    "          errors        = []",
    "          ops_applied   = []",
    "          exec_status   = 'completed'",
    "",
    "          # ── УРОВЕНЬ 2: Произвольный Python скрипт ──────────────────────",
    "          script_match = re.search(r'Run script:\\s*\\n\\s*\"\"\"(.*?)\"\"\"', objective, re.DOTALL)",
    "          if not script_match:",
    "              script_match = re.search(r\"Run script:\\s*\\n\\s*'''(.*?)'''\", objective, re.DOTALL)",
    "",
    "          if script_match:",
    "              script_code = script_match.group(1)",
    "              forbidden = ['requests', 'urllib', 'subprocess', 'os.system',",
    "                           'os.popen', 'socket', 'exec(', 'eval(', '__import__']",
    "              blocked = [f for f in forbidden if f in script_code]",
    "              if blocked:",
    "                  errors.append('Script blocked: forbidden calls: ' + ', '.join(blocked))",
    "                  exec_status = 'failed'",
    "              else:",
    "                  print('Running custom script...')",
    "                  try:",
    "                      safe_globals = {",
    "                          '__builtins__': {",
    "                              'print': print, 'len': len, 'str': str, 'int': int,",
    "                              'float': float, 'bool': bool, 'list': list, 'dict': dict,",
    "                              'tuple': tuple, 'set': set, 'range': range, 'enumerate': enumerate,",
    "                              'zip': zip, 'map': map, 'filter': filter, 'sorted': sorted,",
    "                              'min': min, 'max': max, 'sum': sum, 'any': any, 'all': all,",
    "                              'isinstance': isinstance, 'type': type, 'repr': repr,",
    "                              'open': open, 'True': True, 'False': False, 'None': None,",
    "                          },",
    "                          'json': json, 'Path': Path, 're': re,",
    "                          'datetime': datetime, 'timezone': timezone,",
    "                          'now': now, 'trace': trace, 'shutil': shutil,",
    "                          'changed_files': changed_files, 'ops_applied': ops_applied,",
    "                      }",
    "                      exec(script_code, safe_globals)",
    "                      if 'changed_files' in safe_globals:",
    "                          changed_files = safe_globals['changed_files']",
    "                      ops_applied.append('custom_script')",
    "                      print('Script executed successfully')",
    "                  except Exception as e:",
    "                      errors.append('Script error: ' + str(e))",
    "                      exec_status = 'failed'",
    "",
    "          # ── УРОВЕНЬ 1: Паттерны ─────────────────────────────────────────",
    "",
    "          # 1. Create file",
    "          for m in re.finditer(",
    "              r'Create\\s+file\\s+([^\\s]+)\\s+with\\s+content\\s+[\"\\']?(.*?)[\"\\']?\\s*(?=\\.|Create|Delete|Move|Copy|Append|Prepend|Set|Replace|Insert|Run|$)',",
    "              objective, re.DOTALL | re.IGNORECASE",
    "          ):",
    "              target, content = m.group(1).strip(), m.group(2).strip()",
    "              try:",
    "                  p = Path(target)",
    "                  p.parent.mkdir(parents=True, exist_ok=True)"
  ],
